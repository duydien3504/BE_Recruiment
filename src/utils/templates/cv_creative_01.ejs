<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV StitchRecruit - Creative</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800&family=Open+Sans:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        @page { size: A4; margin: 0; }
        * { box-sizing: border-box; -webkit-print-color-adjust: exact; }

        body {
            font-family: '<%=themeConfig.fontFamily || "Raleway"%>', sans-serif;
            margin: 0; padding: 0; background: #fff;
            line-height: <%=themeConfig.lineSpacing || 1.5%>;
            letter-spacing: <%=themeConfig.charSpacing || 0%>px;
        }

        .cv-container { display: flex; min-height: 297mm; width: 210mm; margin: 0 auto; }

        /* ===================== SIDEBAR ===================== */
        .sidebar { width: 70mm; background: #1c1c2e; color: #fff; display: flex; flex-direction: column; flex-shrink: 0; }

        .avatar-zone {
            padding: 32px 20px 22px;
            background: linear-gradient(160deg, <%=themeConfig.primaryColor || '#E9A800'%>22, transparent 70%);
            text-align: center;
        }
        .avatar-ring {
            width: 120px; height: 120px; border-radius: 50%;
            border: 4px solid <%=themeConfig.primaryColor || '#E9A800'%>;
            margin: 0 auto 14px; overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            background: #2d3e50;
        }
        .avatar-ring img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .sb-name {
            font-size: 19px; font-weight: 800; letter-spacing: 0.5px;
            color: <%=themeConfig.primaryColor || '#E9A800'%>;
            text-transform: uppercase; line-height: 1.2; margin-bottom: 5px;
        }
        .sb-title { font-size: 10px; color: #aaa; font-weight: 400; font-style: italic; }

        .sb-body { padding: 18px 20px; flex: 1; }
        .sb-section { margin-bottom: 22px; }
        .sb-section-title {
            font-size: 9px; font-weight: 700; text-transform: uppercase;
            letter-spacing: 1.8px; color: <%=themeConfig.primaryColor || '#E9A800'%>;
            border-bottom: 1px solid <%=themeConfig.primaryColor || '#E9A800'%>55;
            padding-bottom: 5px; margin-bottom: 12px;
        }

        /* Contact */
        .contact-row { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 9px; }
        .contact-icon-wrap {
            width: 20px; height: 20px; border-radius: 50%;
            background: <%=themeConfig.primaryColor || '#E9A800'%>22;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; color: <%=themeConfig.primaryColor || '#E9A800'%>;
        }
        .contact-val { font-size: 9.5px; color: #ccc; line-height: 1.4; padding-top: 2px; word-break: break-all; }

        /* About / Skills in sidebar */
        .sb-text { font-size: 9px; color: #bbb; line-height: 1.6; }
        .sb-text p { margin: 0 0 4px; }
        .sb-text ul { padding-left: 14px; margin: 0; }
        .sb-text li { margin-bottom: 3px; }

        /* Sidebar items (dynamic sections) */
        .sb-item { margin-bottom: 10px; }
        .sb-item-name { font-size: 10px; font-weight: 700; color: #fff; }
        .sb-item-subtitle { font-size: 9px; color: <%=themeConfig.primaryColor || '#E9A800'%>; margin: 1px 0; }
        .sb-item-period { font-size: 8.5px; color: #888; }

        /* ===================== MAIN ===================== */
        .main-content { flex: 1; padding: 35px 28px; background: #fff; }

        .main-section { margin-bottom: 26px; }
        .main-section-header {
            display: flex; align-items: center; gap: 10px;
            margin-bottom: 14px; padding-bottom: 7px;
            border-bottom: 2px solid <%=themeConfig.primaryColor || '#E9A800'%>;
        }
        .main-icon-circle {
            width: 28px; height: 28px; border-radius: 50%;
            background: <%=themeConfig.primaryColor || '#E9A800'%>;
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .main-section-title {
            font-size: 13px; font-weight: 800; text-transform: uppercase;
            color: #1c1c2e; letter-spacing: 0.6px;
        }

        /* Timeline items */
        .tl-item { display: flex; gap: 12px; margin-bottom: 16px; }
        .tl-dot {
            width: 9px; height: 9px; border-radius: 50%; margin-top: 5px;
            background: <%=themeConfig.primaryColor || '#E9A800'%>; flex-shrink: 0;
        }
        .tl-body { flex: 1; }
        .tl-head { display: flex; justify-content: space-between; align-items: flex-start; }
        .tl-name { font-size: 12px; font-weight: 700; color: #1c1c2e; }
        .tl-period { font-size: 9px; color: #888; font-weight: 500; }
        .tl-subtitle { font-size: 10px; font-style: italic; color: #555; margin: 2px 0 5px; }
        .tl-desc { font-size: 9.5px; color: #444; line-height: 1.5; }
        .tl-desc p { margin: 0 0 3px; }
        .tl-desc ul { padding-left: 13px; margin: 0; }
        .tl-desc li { margin-bottom: 2px; }

        /* About in main */
        .main-about { font-size: 10.5px; color: #444; line-height: 1.7; text-align: justify; }
        .main-about p { margin: 0 0 5px; }

        .prose ul { padding-left: 1.2rem; margin: 0.3rem 0; }
        .prose li { margin-bottom: 2px; }
        .prose p { margin: 0 0 4px; }
    </style>
</head>
<body>
<%
const layout = columnLayout || { left: ['profile','contact','about','skills'], right: ['experience','education','projects'] };
const LABELS = {
    contact:'Liên hệ', about:'Giới thiệu', skills:'Kỹ năng',
    experience:'Kinh nghiệm', education:'Học vấn', projects:'Dự án', awards:'Giải thưởng'
};
const ICONS = {
    experience:'<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>',
    education:'<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>',
    projects:'<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>',
    awards:'<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>'
};
%>
<div class="cv-container">
    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="avatar-zone">
            <div class="avatar-ring">
                <% if (cvData.personal && cvData.personal.avatarUrl) { %>
                    <img src="<%=cvData.personal.avatarUrl%>" alt="Avatar">
                <% } else { %>
                    <svg width="50" height="50" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="1.5">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                    </svg>
                <% } %>
            </div>
            <div class="sb-name"><%- (cvData.personal && cvData.personal.fullName) || 'Họ Tên' %></div>
            <div class="sb-title"><%- (cvData.personal && cvData.personal.title) || 'Vị trí ứng tuyển' %></div>
        </div>

        <div class="sb-body">
            <% layout.left.forEach(function(sectionId) { %>
                <% if (sectionId === 'profile' || sectionId === 'contact') { %>
                    <div class="sb-section">
                        <div class="sb-section-title">Liên hệ</div>
                        <% if (cvData.personal) { %>
                            <% if (cvData.personal.phoneNumber) { %>
                                <div class="contact-row">
                                    <div class="contact-icon-wrap">
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                    </div>
                                    <div class="contact-val"><%=cvData.personal.phoneNumber%></div>
                                </div>
                            <% } %>
                            <% if (cvData.personal.email) { %>
                                <div class="contact-row">
                                    <div class="contact-icon-wrap">
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                                    </div>
                                    <div class="contact-val"><%=cvData.personal.email%></div>
                                </div>
                            <% } %>
                            <% if (cvData.personal.address) { %>
                                <div class="contact-row">
                                    <div class="contact-icon-wrap">
                                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                                    </div>
                                    <div class="contact-val"><%=cvData.personal.address%></div>
                                </div>
                            <% } %>
                        <% } %>
                    </div>
                <% } else if (sectionId === 'about') { %>
                    <div class="sb-section">
                        <div class="sb-section-title">Giới thiệu</div>
                        <div class="sb-text"><%- cvData.about || '' %></div>
                    </div>
                <% } else if (sectionId === 'skills') { %>
                    <div class="sb-section">
                        <div class="sb-section-title">Kỹ năng</div>
                        <div class="sb-text"><%- cvData.skills || '' %></div>
                    </div>
                <% } else { %>
                    <% const sbItems = cvData[sectionId] || []; %>
                    <% if (sbItems.length > 0) { %>
                        <div class="sb-section">
                            <div class="sb-section-title"><%= cvData.customLabels && cvData.customLabels[sectionId] ? cvData.customLabels[sectionId] : (LABELS[sectionId] || sectionId.toUpperCase()) %></div>
                            <% sbItems.forEach(function(item) { %>
                                <div class="sb-item">
                                    <div class="sb-item-name"><%- item.school || item.company || item.name %></div>
                                    <div class="sb-item-subtitle"><%- item.degree || item.title || '' %></div>
                                    <div class="sb-item-period"><%- item.period || '' %></div>
                                </div>
                            <% }); %>
                        </div>
                    <% } %>
                <% } %>
            <% }); %>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        <% layout.right.forEach(function(sectionId) { %>
            <% if (sectionId === 'about') { %>
                <div class="main-section">
                    <div class="main-section-header">
                        <div class="main-icon-circle">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
                        </div>
                        <div class="main-section-title">Giới thiệu</div>
                    </div>
                    <div class="main-about prose"><%- cvData.about || '' %></div>
                </div>
            <% } else if (sectionId === 'skills') { %>
                <div class="main-section">
                    <div class="main-section-header">
                        <div class="main-icon-circle">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3z"/></svg>
                        </div>
                        <div class="main-section-title">Kỹ năng</div>
                    </div>
                    <div class="main-about prose"><%- cvData.skills || '' %></div>
                </div>
            <% } else { %>
                <% const items = cvData[sectionId] || []; %>
                <% if (items.length > 0) { %>
                    <div class="main-section">
                        <div class="main-section-header">
                            <div class="main-icon-circle"><%- ICONS[sectionId] || '' %></div>
                            <div class="main-section-title"><%= cvData.customLabels && cvData.customLabels[sectionId] ? cvData.customLabels[sectionId] : (LABELS[sectionId] || sectionId) %></div>
                        </div>
                        <% items.forEach(function(item) { %>
                            <div class="tl-item">
                                <div class="tl-dot"></div>
                                <div class="tl-body">
                                    <div class="tl-head">
                                        <div class="tl-name"><%- item.school || item.company || item.name %></div>
                                        <div class="tl-period"><%- item.period || '' %></div>
                                    </div>
                                    <div class="tl-subtitle"><%- item.degree || item.title || '' %></div>
                                    <div class="tl-desc prose"><%- item.description || '' %></div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            <% } %>
        <% }); %>
    </div>
</div>
</body>
</html>
