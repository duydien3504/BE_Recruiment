<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV StitchRecruit</title>
    <!-- Import Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600;700&family=Roboto:ital,wght@0,400;0,500;0,700;1,400&display=swap"
        rel="stylesheet">

    <style>
        @page {
            size: A4;
            margin: 0;
        }

        * {
            box-sizing: border-box;
            -webkit-print-color-adjust: exact;
        }

        body {
            font-family: '<%= themeConfig.fontFamily || ' Be Vietnam Pro' %>', Arial, sans-serif;
            color: #333;
            margin: 0;
            padding: 0;
            background-color: #fff;
            line-height: <%=themeConfig.lineSpacing || 1.4 %>;
            letter-spacing: <%=themeConfig.charSpacing || 0 %>px;
        }

        .cv-container {
            display: flex;
            min-height: 297mm;
            width: 210mm;
            margin: 0 auto;
        }

        /* Sidebar */
        .sidebar {
            width: 75mm;
            background-color: #2d3e50;
            color: #ffffff;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
        }

        .avatar-container {
            text-align: center;
            margin-bottom: 30px;
        }

        .avatar {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            border: 4px solid rgba(255, 255, 255, 0.15);
            object-fit: cover;
            display: block;
            margin: 0 auto 15px auto;
        }

        .full-name {
            font-size: 20px;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 6px;
            letter-spacing: 1.2px;
            color: #ffffff;
        }

        .job-title {
            font-size: 12px;
            font-style: italic;
            color: #a0aec0;
            margin-bottom: 0;
        }

        .sidebar-section {
            margin-bottom: 25px;
        }

        .sidebar-title {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 5px;
            margin-bottom: 12px;
            color: <%=themeConfig.primaryColor || '#00b14f' %>;
        }

        .contact-item {
            display: flex;
            align-items: flex-start;
            margin-bottom: 10px;
            font-size: 9.5px;
        }

        .contact-icon {
            width: 18px;
            height: 18px;
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            margin-right: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            color: <%=themeConfig.primaryColor || '#00b14f' %>;
        }

        .contact-text {
            color: #edf2f7;
            padding-top: 1px;
        }

        .sidebar-text {
            font-size: 9.5px;
            line-height: 1.5;
            color: rgba(255, 255, 255, 0.85);
        }

        /* Main Content */
        .main-content {
            flex: 1;
            padding: 40px 35px;
            background-color: #ffffff;
        }

        .section {
            margin-bottom: 30px;
        }

        .section-header {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }

        .section-icon {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background-color: <%=themeConfig.primaryColor || '#00b14f' %>;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            flex-shrink: 0;
        }

        .section-title-main {
            font-size: 16px;
            font-weight: 700;
            text-transform: uppercase;
            color: #2d3748;
            letter-spacing: 0.5px;
        }

        .item {
            margin-bottom: 18px;
        }

        .item-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 3px;
        }

        .item-name {
            font-weight: 700;
            font-size: 13px;
            color: #2d3748;
        }

        .item-period {
            font-size: 10.5px;
            color: #718096;
            font-weight: 500;
        }

        .item-subtitle {
            font-size: 11px;
            font-style: italic;
            color: #4a5568;
            margin-bottom: 6px;
            font-weight: 500;
        }

        .item-description {
            font-size: 11px;
            color: #4a5568;
            line-height: 1.5;
        }

        /* Sidebar version of Items */
        .sidebar-item {
            margin-bottom: 15px;
        }

        .sidebar-item-header {
            margin-bottom: 2px;
        }

        .sidebar-item-name {
            font-weight: 700;
            font-size: 11px;
            color: #ffffff;
            display: block;
        }

        .sidebar-item-period {
            font-size: 9px;
            color: #a0aec0;
            display: block;
            margin-top: 2px;
        }

        .sidebar-item-subtitle {
            font-size: 10px;
            font-style: italic;
            color: <%=themeConfig.primaryColor || '#00b14f' %>;
            margin-bottom: 4px;
        }

        .sidebar-item-description {
            font-size: 9.5px;
            color: rgba(255, 255, 255, 0.7);
        }

        /* Tiptap Helper Styles */
        .prose ul {
            padding-left: 1.2rem;
            margin: 0.4rem 0;
        }

        .prose li {
            margin-bottom: 0.2rem;
        }

        .prose p {
            margin: 0 0 0.4rem 0;
        }

        .prose strong {
            color: inherit;
            font-weight: 700;
        }
    </style>
</head>

<body>
    <% const SECTION_ICONS={
        education: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>'
        ,
        experience: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>'
        ,
        projects: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>'
        ,
        awards: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>'
        }; const SECTION_LABELS={ profile: 'ẢNH & HỌ TÊN' , contact: 'LIÊN HỆ' , about: 'MỤC TIÊU NGHỀ NGHIỆP' ,
        skills: 'KỸ NĂNG' , education: 'HỌC VẤN' , experience: 'KINH NGHIỆM LÀM VIỆC' , projects: 'DỰ ÁN CÁ NHÂN' ,
        awards: 'GIẢI THƯỞNG' }; const layout=columnLayout || { left: ['profile', 'contact' , 'about' , 'skills' ],
        right: ['experience', 'education' , 'projects' ] }; %>

        <div class="cv-container">
            <!-- Sidebar -->
            <div class="sidebar">
                <% layout.left.forEach(function(sectionId) { %>
                    <% if (sectionId==='profile' ) { %>
                        <div class="avatar-container">
                            <% if (cvData.personal?.avatarUrl) { %>
                                <img src="<%= cvData.personal.avatarUrl %>" class="avatar" alt="Avatar">
                                <% } else { %>
                                    <div class="avatar"
                                        style="background-color: #4a5568; display: flex; align-items: center; justify-content: center;">
                                        <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="white"
                                            stroke-width="1.5">
                                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                            <circle cx="12" cy="7" r="4" />
                                        </svg>
                                    </div>
                                    <% } %>
                                        <div class="full-name"><%- cvData.personal?.fullName || 'CHƯA CẬP NHẬT' %></div>
                                        <div class="job-title"><%- cvData.personal?.title || 'Vị trí ứng tuyển' %></div>
                        </div>
                        <% } else if (sectionId==='contact' ) { %>
                            <div class="sidebar-section">
                                <div class="sidebar-title">
                                    <%= SECTION_LABELS.contact %>
                                </div>
                                <div class="contact-item">
                                    <div class="contact-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10"
                                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <path
                                                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                                        </svg>
                                    </div>
                                    <div class="contact-text"><%- cvData.personal?.phoneNumber || '' %></div>
                                </div>
                                <div class="contact-item">
                                    <div class="contact-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10"
                                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <rect width="20" height="16" x="2" y="4" rx="2" />
                                            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                                        </svg>
                                    </div>
                                    <div class="contact-text"><%- cvData.personal?.email || '' %></div>
                                </div>
                                <div class="contact-item">
                                    <div class="contact-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10"
                                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                                            <circle cx="12" cy="10" r="3" />
                                        </svg>
                                    </div>
                                    <div class="contact-text"><%- cvData.personal?.address || '' %></div>
                                </div>
                            </div>
                            <% } else if (sectionId==='about' ) { %>
                                <div class="sidebar-section">
                                    <div class="sidebar-title">
                                        <%= SECTION_LABELS.about %>
                                    </div>
                                    <div class="sidebar-text prose">
                                        <%- cvData.about || '' %>
                                    </div>
                                </div>
                                <% } else if (sectionId==='skills' ) { %>
                                    <div class="sidebar-section">
                                        <div class="sidebar-title">
                                            <%= SECTION_LABELS.skills %>
                                        </div>
                                        <div class="sidebar-text prose">
                                            <%- cvData.skills || '' %>
                                        </div>
                                    </div>
                                    <% } else { %>
                                        <!-- Dynamic Section in Sidebar -->
                                        <% let items=cvData[sectionId] || []; %>
                                            <% if (items.length> 0) { %>
                                                <div class="sidebar-section">
                                                    <div class="sidebar-title"><%- cvData.customLabels?.[sectionId] ||
                                                            SECTION_LABELS[sectionId] || sectionId.toUpperCase() %>
                                                    </div>
                                                    <% items.forEach(function(item) { %>
                                                        <div class="sidebar-item">
                                                            <div class="sidebar-item-header">
                                                                <span class="sidebar-item-name"><%- item.school ||
                                                                        item.company || item.name %></span>
                                                                <span class="sidebar-item-period"><%- item.period
                                                                        %></span>
                                                            </div>
                                                            <div class="sidebar-item-subtitle"><%- item.degree ||
                                                                    item.title %></div>
                                                            <div class="sidebar-item-description prose"><%-
                                                                    item.description %></div>
                                                        </div>
                                                        <% }); %>
                                                </div>
                                                <% } %>
                                                    <% } %>
                                                        <% }); %>
            </div>

            <!-- Main Content -->
            <div class="main-content">
                <% layout.right.forEach(function(sectionId) { %>
                    <% if (['profile', 'contact' , 'about' , 'skills' ].includes(sectionId)) { %>
                        <!-- Render basic sections in main content if moved there -->
                        <div class="section">
                            <div class="section-header">
                                <div class="section-title-main"><%- SECTION_LABELS[sectionId] %></div>
                            </div>
                            <div class="item-description prose">
                                <% if (sectionId==='about' ) { %>
                                    <%- cvData.about %>
                                        <% } else if (sectionId==='skills' ) { %>
                                            <%- cvData.skills %>
                                                <% } else if (sectionId==='contact' ) { %>
                                                    <p>SĐT: <%- cvData.personal?.phoneNumber %></p>
                                                    <p>Email: <%- cvData.personal?.email %></p>
                                                    <p>Địa chỉ: <%- cvData.personal?.address %></p>
                                                    <% } %>
                            </div>
                        </div>
                        <% } else { %>
                            <% let items=cvData[sectionId] || []; %>
                                <% if (items.length> 0) { %>
                                    <div class="section">
                                        <div class="section-header">
                                            <div class="section-icon">
                                                <%- SECTION_ICONS[sectionId] || '' %>
                                            </div>
                                            <div class="section-title-main"><%- cvData.customLabels?.[sectionId] ||
                                                    SECTION_LABELS[sectionId] || sectionId %></div>
                                        </div>
                                        <% items.forEach(function(item) { %>
                                            <div class="item">
                                                <div class="item-header">
                                                    <div class="item-name"><%- item.school || item.company || item.name
                                                            %></div>
                                                    <div class="item-period"><%- item.period %></div>
                                                </div>
                                                <div class="item-subtitle"><%- item.degree || item.title %></div>
                                                <div class="item-description prose"><%- item.description %></div>
                                            </div>
                                            <% }); %>
                                    </div>
                                    <% } %>
                                        <% } %>
                                            <% }); %>
            </div>
        </div>
</body>

</html>