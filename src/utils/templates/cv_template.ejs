<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV StitchRecruit - Premium</title>
    <!-- Import Premium Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600;700&family=Roboto:ital,wght@0,400;0,500;0,700;1,400&family=Montserrat:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&family=Merriweather:wght@300;400;700&family=Fira+Code:wght@400;500&display=swap"
        rel="stylesheet">

    <% 
        // Default Configs
        const primaryColor = themeConfig.primaryColor || '#00b14f';
        const secondaryColor = themeConfig.secondaryColor || '#2d3e50';
        const textColor = themeConfig.textColor || '#333';
        const layoutMode = themeConfig.layoutMode || 'sidebar-left'; // sidebar-left, sidebar-right, top-header, minimal-1-col
        const fontFamily = themeConfig.fontFamily || 'Be Vietnam Pro';
    %>

    <style>
        @page {
            size: A4;
            margin: 0;
        }

        * {
            box-sizing: border-box;
            -webkit-print-color-adjust: exact;
        }

        body {
            font-family: '<%= fontFamily %>', Arial, sans-serif;
            color: <%= textColor %>;
            margin: 0;
            padding: 0;
            background-color: #fff;
            line-height: <%= themeConfig.lineSpacing || 1.4 %>;
            letter-spacing: <%= themeConfig.charSpacing || 0 %>px;
        }

        .cv-container {
            display: flex;
            flex-direction: <%= (layoutMode === 'top-header' || layoutMode === 'minimal-1-col') ? 'column' : (layoutMode === 'sidebar-right' ? 'row-reverse' : 'row') %>;
            min-height: 297mm;
            width: 210mm;
            margin: 0 auto;
            position: relative;
        }

        /* Top Header Layout specific */
        .header-top {
            width: 100%;
            background-color: <%= secondaryColor %>;
            color: white;
            padding: 40px 50px;
            display: <%= layoutMode === 'top-header' ? 'flex' : 'none' %>;
            align-items: center;
            justify-content: space-between;
        }

        /* Sidebar Styling */
        .sidebar {
            width: <%= (layoutMode === 'minimal-1-col') ? '100%' : '75mm' %>;
            background-color: <%= secondaryColor %>;
            color: #ffffff;
            padding: 40px 25px;
            display: <%= (layoutMode === 'top-header' || layoutMode === 'minimal-1-col') ? 'none' : 'flex' %>;
            flex-direction: column;
            flex-shrink: 0;
        }

        /* Main Content Styling */
        .main-content {
            flex: 1;
            padding: 40px 40px;
            background-color: #ffffff;
            display: <%= layoutMode === 'minimal-1-col' ? 'none' : 'block' %>;
        }

        /* Minimal 1-Col Styling */
        .one-column-content {
            width: 100%;
            padding: 50px;
            display: <%= layoutMode === 'minimal-1-col' ? 'block' : 'none' %>;
        }

        /* 2-Columns under Top Header */
        .header-bottom-container {
            display: <%= layoutMode === 'top-header' ? 'flex' : 'none' %>;
            width: 100%;
            flex: 1;
        }

        .header-bottom-left {
            width: 75mm;
            background-color: #f7fafc;
            padding: 30px 25px;
            border-right: 1px solid #edf2f7;
        }

        .header-bottom-right {
            flex: 1;
            padding: 30px 40px;
        }

        /* Reusable Components */
        .avatar-container {
            text-align: center;
            margin-bottom: 30px;
        }

        .avatar {
            width: 140px;
            height: 140px;
            border-radius: <%= themeConfig.avatarBorderRadius || '50%' %>;
            border: 5px solid rgba(255, 255, 255, 0.2);
            object-fit: cover;
            display: block;
            margin: 0 auto 20px auto;
        }

        .full-name {
            font-size: 26px;
            font-weight: 800;
            text-transform: uppercase;
            margin-bottom: 8px;
            letter-spacing: 1.5px;
            color: #ffffff;
        }

        .job-title {
            font-size: 14px;
            font-style: italic;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .header-top .full-name { margin-bottom: 5px; }
        .header-top .avatar { width: 100px; height: 100px; margin: 0; }

        .section-title {
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding-bottom: 8px;
            margin-bottom: 20px;
            position: relative;
        }

        .sidebar .section-title {
            color: <%= primaryColor %>;
            border-bottom: 2px solid rgba(255,255,255,0.1);
        }

        .main-content .section-title-main {
            font-size: 18px;
            font-weight: 800;
            color: #2d3748;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
        }

        .main-content .section-title-main::after {
            content: "";
            flex: 1;
            height: 2px;
            background: #edf2f7;
            margin-left: 15px;
        }

        .section-icon {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            background-color: <%= primaryColor %>;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            flex-shrink: 0;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .contact-item {
            display: flex;
            align-items: center;
            margin-bottom: 12px;
            font-size: 10px;
        }

        .contact-icon {
            width: 22px;
            height: 22px;
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 6px;
            margin-right: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: <%= primaryColor %>;
        }

        .item { margin-bottom: 25px; }
        .item-header { display: flex; justify-content: space-between; margin-bottom: 5px; }
        .item-name { font-weight: 700; font-size: 15px; color: #1a202c; }
        .item-period { font-size: 11px; color: #718096; font-weight: 600; background: #f7fafc; padding: 2px 8px; border-radius: 4px; }
        .item-subtitle { font-size: 12px; color: <%= primaryColor %>; font-weight: 600; margin-bottom: 8px; }
        .item-description { font-size: 11.5px; color: #4a5568; line-height: 1.6; }

        .tag-container { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
        .tag { padding: 4px 10px; background: rgba(255,255,255,0.1); border-radius: 4px; font-size: 10px; color: #fff; }
        .main-content .tag { background: #edf2f7; color: #2d3748; }

        .prose ul { padding-left: 1.2rem; margin: 8px 0; }
        .prose li { margin-bottom: 5px; }
    </style>
</head>

<body>
    <% 
        const SECTION_ICONS = {
            education: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>',
            experience: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>',
            projects: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>',
            awards: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>'
        };

        const SECTION_LABELS = {
            profile: 'THÔNG TIN CÁ NHÂN',
            contact: 'THÔNG TIN LIÊN HỆ',
            about: 'GIỚI THIỆU BẢN THÂN',
            skills: 'KỸ NĂNG CHUYÊN MÔN',
            education: 'QUÁ TRÌNH HỌC TẬP',
            experience: 'KINH NGHIỆM LÀM VIỆC',
            projects: 'DỰ ÁN TIÊU BIỂU',
            awards: 'GIẢI THƯỞNG'
        };

        const layout = columnLayout || { 
            left: ['profile', 'contact', 'about', 'skills'], 
            right: ['experience', 'education', 'projects'] 
        };
    %>

    <div class="cv-container">
        <!-- TOP HEADER LAYOUT -->
        <% if (layoutMode === 'top-header') { %>
            <div class="header-top">
                <div class="header-info">
                    <div class="full-name"><%- cvData.personal?.fullName || 'HỌ VÀ TÊN' %></div>
                    <div class="job-title"><%- cvData.personal?.title || 'Vị trí công việc' %></div>
                    <div style="display: flex; gap: 20px; margin-top: 15px; font-size: 11px; color: rgba(255,255,255,0.8);">
                        <span><%- cvData.personal?.email %></span>
                        <span><%- cvData.personal?.phoneNumber %></span>
                    </div>
                </div>
                <div class="header-avatar">
                    <% if (cvData.personal?.avatarUrl) { %>
                        <img src="<%= cvData.personal.avatarUrl %>" class="avatar" alt="Avatar">
                    <% } %>
                </div>
            </div>
            <div class="header-bottom-container">
                <div class="header-bottom-left">
                    <% layout.left.forEach(function(sId) { if(sId !== 'profile' && sId !== 'contact') { %>
                        <div class="section">
                            <h3 class="section-title" style="color: <%= secondaryColor %>; border-bottom: 2px solid <%= primaryColor %>;"><%= SECTION_LABELS[sId] %></h3>
                            <div class="prose" style="font-size: 11px;"><%- cvData[sId] || '' %></div>
                        </div>
                    <% } }); %>
                </div>
                <div class="header-bottom-right">
                    <% layout.right.forEach(function(sId) { %>
                        <div class="section">
                            <div class="section-title-main">
                                <div class="section-icon"><%- SECTION_ICONS[sId] || '' %></div>
                                <%= SECTION_LABELS[sId] %>
                            </div>
                            <% (cvData[sId] || []).forEach(function(item) { %>
                                <div class="item">
                                    <div class="item-header">
                                        <div class="item-name"><%- item.school || item.company || item.name %></div>
                                        <div class="item-period"><%- item.period %></div>
                                    </div>
                                    <div class="item-subtitle"><%- item.degree || item.title %></div>
                                    <div class="item-description prose"><%- item.description %></div>
                                </div>
                            <% }); %>
                        </div>
                    <% }); %>
                </div>
            </div>
        <% } %>

        <!-- SIDEBAR LAYOUT (Left or Right) -->
        <% if (layoutMode === 'sidebar-left' || layoutMode === 'sidebar-right') { %>
            <div class="sidebar">
                <% layout.left.forEach(function(sId) { %>
                    <% if (sId === 'profile') { %>
                        <div class="avatar-container">
                            <% if (cvData.personal?.avatarUrl) { %>
                                <img src="<%= cvData.personal.avatarUrl %>" class="avatar" alt="Avatar">
                            <% } else { %>
                                <div class="avatar" style="background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center;">
                                    <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                                </div>
                            <% } %>
                            <div class="full-name"><%- cvData.personal?.fullName || 'HỌ VÀ TÊN' %></div>
                            <div class="job-title"><%- cvData.personal?.title || 'Vị trí công việc' %></div>
                        </div>
                    <% } else if (sId === 'contact') { %>
                        <div class="section">
                            <h3 class="section-title"><%= SECTION_LABELS.contact %></h3>
                            <div class="contact-item">
                                <span class="contact-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" /></svg></span>
                                <span><%- cvData.personal?.phoneNumber %></span>
                            </div>
                            <div class="contact-item">
                                <span class="contact-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg></span>
                                <span><%- cvData.personal?.email %></span>
                            </div>
                            <div class="contact-item">
                                <span class="contact-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" /></svg></span>
                                <span><%- cvData.personal?.address %></span>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="section">
                            <h3 class="section-title"><%= SECTION_LABELS[sId] || sId.toUpperCase() %></h3>
                            <div class="prose" style="font-size: 11px; opacity: 0.9;"><%- cvData[sId] || '' %></div>
                        </div>
                    <% } %>
                <% }); %>
            </div>
            <div class="main-content">
                <% layout.right.forEach(function(sId) { %>
                    <div class="section">
                        <div class="section-title-main">
                            <div class="section-icon"><%- SECTION_ICONS[sId] || '' %></div>
                            <%= SECTION_LABELS[sId] %>
                        </div>
                        <% (cvData[sId] || []).forEach(function(item) { %>
                            <div class="item">
                                <div class="item-header">
                                    <div class="item-name"><%- item.school || item.company || item.name %></div>
                                    <div class="item-period"><%- item.period %></div>
                                </div>
                                <div class="item-subtitle"><%- item.degree || item.title %></div>
                                <div class="item-description prose"><%- item.description %></div>
                            </div>
                        <% }); %>
                    </div>
                <% }); %>
            </div>
        <% } %>

        <!-- 1-COLUMN LAYOUT -->
        <% if (layoutMode === 'minimal-1-col') { %>
            <div class="one-column-content">
                <header style="margin-bottom: 40px; text-align: center;">
                    <div class="full-name" style="color: #2d3748; font-size: 32px;"><%- cvData.personal?.fullName %></div>
                    <div class="job-title" style="color: <%= primaryColor %>; font-size: 16px;"><%- cvData.personal?.title %></div>
                    <div style="margin-top: 15px; font-size: 11px; color: #718096; display: flex; justify-content: center; gap: 20px;">
                        <span><%- cvData.personal?.email %></span> | <span><%- cvData.personal?.phoneNumber %></span> | <span><%- cvData.personal?.address %></span>
                    </div>
                </header>
                
                <% [...layout.left, ...layout.right].forEach(function(sId) { if(sId !== 'profile' && sId !== 'contact') { %>
                    <div class="section">
                        <div class="section-title-main">
                            <div class="section-icon"><%- SECTION_ICONS[sId] || '' %></div>
                            <%= SECTION_LABELS[sId] %>
                        </div>
                        <% if (Array.isArray(cvData[sId])) { %>
                            <% cvData[sId].forEach(function(item) { %>
                                <div class="item">
                                    <div class="item-header">
                                        <div class="item-name"><%- item.school || item.company || item.name %></div>
                                        <div class="item-period"><%- item.period %></div>
                                    </div>
                                    <div class="item-subtitle"><%- item.degree || item.title %></div>
                                    <div class="item-description prose"><%- item.description %></div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="prose" style="font-size: 12px;"><%- cvData[sId] %></div>
                        <% } %>
                    </div>
                <% } }); %>
            </div>
        <% } %>
    </div>
</body>
</html>

            </div>
        </div>
</body>

</html>