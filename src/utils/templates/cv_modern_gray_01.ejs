<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV StitchRecruit - Modern Gray</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&family=Roboto+Condensed:wght@400;700&display=swap" rel="stylesheet">
    <style>
        @page { size: A4; margin: 0; }
        * { box-sizing: border-box; -webkit-print-color-adjust: exact; }

        body {
            font-family: '<%=themeConfig.fontFamily || "Be Vietnam Pro"%>', sans-serif;
            margin: 0; padding: 0; background: #fff; color: #333;
            line-height: <%=themeConfig.lineSpacing || 1.5%>;
            letter-spacing: <%=themeConfig.charSpacing || 0%>px;
        }

        .cv-container { display: flex; min-height: 297mm; width: 210mm; margin: 0 auto; }

        /* ===================== SIDEBAR ===================== */
        .sidebar { width: 66mm; background: #3a3a3a; color: #eee; padding: 0; flex-shrink: 0; }

        /* Avatar block */
        .avatar-block { padding: 28px 20px 20px; text-align: center; border-bottom: 1px solid #555; }
        .avatar-circle {
            width: 100px; height: 100px; border-radius: 50%;
            border: 3px solid <%=themeConfig.primaryColor || '#4CAF50'%>;
            margin: 0 auto 14px; overflow: hidden;
            display: flex; align-items: center; justify-content: center; background: #555;
        }
        .avatar-circle img { width: 100%; height: 100%; object-fit: cover; }
        .avatar-name { font-size: 16px; font-weight: 700; color: #fff; line-height: 1.2; text-transform: uppercase; letter-spacing: 0.5px; }
        .avatar-title { font-size: 9.5px; color: #aaa; margin-top: 4px; }

        /* Sidebar sections */
        .sb-block { padding: 16px 18px; border-bottom: 1px solid #555; }
        .sb-block:last-child { border-bottom: none; }
        .sb-label {
            font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px;
            color: <%=themeConfig.primaryColor || '#4CAF50'%>;
            margin-bottom: 10px;
        }

        /* Contact in sidebar */
        .sb-contact-item { display: flex; align-items: flex-start; gap: 7px; margin-bottom: 8px; }
        .sb-contact-icon { color: <%=themeConfig.primaryColor || '#4CAF50'%>; flex-shrink: 0; }
        .sb-contact-text { font-size: 9px; color: #ccc; line-height: 1.4; word-break: break-all; }

        /* Text sections */
        .sb-content { font-size: 9.5px; color: #ccc; line-height: 1.6; }
        .sb-content p { margin: 0 0 4px; }
        .sb-content ul { padding-left: 14px; margin: 0; }
        .sb-content li { margin-bottom: 3px; }

        /* ===================== MAIN ===================== */
        .main-content { flex: 1; padding: 28px 26px 28px 24px; background: #fff; }

        /* Main sections */
        .main-block { margin-bottom: 22px; }
        .main-block-title {
            font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.8px;
            color: #333; padding-bottom: 6px; margin-bottom: 14px;
            border-bottom: 2px solid <%=themeConfig.primaryColor || '#4CAF50'%>;
        }

        /* Timeline - 2 col (date left, content right) */
        .tl-row { display: flex; margin-bottom: 16px; gap: 10px; }
        .tl-date-col { width: 36mm; flex-shrink: 0; }
        .tl-date-company { font-size: 9px; color: #888; font-weight: 600; }
        .tl-date-val { font-size: 8.5px; color: #aaa; }
        .tl-dot-col { display: flex; flex-direction: column; align-items: center; width: 12px; flex-shrink: 0; }
        .tl-dot {
            width: 10px; height: 10px; border-radius: 50%;
            background: <%=themeConfig.primaryColor || '#4CAF50'%>; flex-shrink: 0; margin-top: 3px;
        }
        .tl-vline { width: 1.5px; background: #ddd; flex: 1; margin-top: 3px; }
        .tl-main-col { flex: 1; }
        .tl-main-title { font-size: 11.5px; font-weight: 700; color: #222; margin-bottom: 2px; }
        .tl-main-sub { font-size: 9.5px; color: <%=themeConfig.primaryColor || '#4CAF50'%>; font-style: italic; margin-bottom: 4px; }
        .tl-main-desc { font-size: 9.5px; color: #444; line-height: 1.6; }
        .tl-main-desc p { margin: 0 0 3px; }
        .tl-main-desc ul { padding-left: 13px; margin: 3px 0; }
        .tl-main-desc li { margin-bottom: 2px; }

        /* About block */
        .about-text { font-size: 10.5px; color: #444; line-height: 1.7; text-align: justify; }
        .about-text p { margin: 0 0 5px; }

        .prose ul { padding-left: 1.2rem; margin: 0.3rem 0; }
        .prose li { margin-bottom: 2px; }
        .prose p { margin: 0 0 4px; }
    </style>
</head>
<body>
<%
const layout = columnLayout || { left: ['profile','contact','about','skills'], right: ['experience','education','projects'] };
const LABELS = {
    contact:'Liên hệ', about:'Giới thiệu', skills:'Kỹ năng',
    experience:'Kinh nghiệm làm việc', education:'Học vấn', projects:'Dự án', awards:'Giải thưởng'
};
%>
<div class="cv-container">
    <!-- SIDEBAR -->
    <div class="sidebar">
        <!-- Avatar -->
        <div class="avatar-block">
            <div class="avatar-circle">
                <% if (cvData.personal && cvData.personal.avatarUrl) { %>
                    <img src="<%=cvData.personal.avatarUrl%>" alt="Avatar">
                <% } else { %>
                    <svg width="45" height="45" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                    </svg>
                <% } %>
            </div>
            <div class="avatar-name"><%- (cvData.personal && cvData.personal.fullName) || 'Họ Tên' %></div>
            <div class="avatar-title"><%- (cvData.personal && cvData.personal.title) || 'Vị trí ứng tuyển' %></div>
        </div>

        <% layout.left.forEach(function(sectionId) { %>
            <% if (sectionId === 'profile' || sectionId === 'contact') { %>
                <div class="sb-block">
                    <div class="sb-label">Liên hệ</div>
                    <% if (cvData.personal) { %>
                        <% if (cvData.personal.phoneNumber) { %>
                            <div class="sb-contact-item">
                                <div class="sb-contact-icon"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
                                <div class="sb-contact-text"><%=cvData.personal.phoneNumber%></div>
                            </div>
                        <% } %>
                        <% if (cvData.personal.email) { %>
                            <div class="sb-contact-item">
                                <div class="sb-contact-icon"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div>
                                <div class="sb-contact-text"><%=cvData.personal.email%></div>
                            </div>
                        <% } %>
                        <% if (cvData.personal.address) { %>
                            <div class="sb-contact-item">
                                <div class="sb-contact-icon"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
                                <div class="sb-contact-text"><%=cvData.personal.address%></div>
                            </div>
                        <% } %>
                    <% } %>
                </div>
            <% } else if (sectionId === 'about') { %>
                <div class="sb-block">
                    <div class="sb-label">Giới thiệu</div>
                    <div class="sb-content"><%- cvData.about || '' %></div>
                </div>
            <% } else if (sectionId === 'skills') { %>
                <div class="sb-block">
                    <div class="sb-label">Kỹ năng</div>
                    <div class="sb-content"><%- cvData.skills || '' %></div>
                </div>
            <% } else { %>
                <% const sbItems = cvData[sectionId] || []; %>
                <% if (sbItems.length > 0) { %>
                    <div class="sb-block">
                        <div class="sb-label"><%= cvData.customLabels && cvData.customLabels[sectionId] ? cvData.customLabels[sectionId] : (LABELS[sectionId] || sectionId.toUpperCase()) %></div>
                        <% sbItems.forEach(function(item) { %>
                            <div style="margin-bottom:10px;">
                                <div style="font-size:10px;font-weight:600;color:#fff;"><%- item.school || item.company || item.name %></div>
                                <div style="font-size:9px;color:<%=themeConfig.primaryColor || '#4CAF50'%>;"><%- item.degree || item.title || '' %></div>
                                <div style="font-size:8.5px;color:#999;"><%- item.period || '' %></div>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            <% } %>
        <% }); %>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        <% layout.right.forEach(function(sectionId) { %>
            <% if (sectionId === 'about') { %>
                <div class="main-block">
                    <div class="main-block-title">Giới thiệu</div>
                    <div class="about-text prose"><%- cvData.about || '' %></div>
                </div>
            <% } else if (sectionId === 'skills') { %>
                <div class="main-block">
                    <div class="main-block-title">Kỹ năng</div>
                    <div class="about-text prose"><%- cvData.skills || '' %></div>
                </div>
            <% } else { %>
                <% const items = cvData[sectionId] || []; %>
                <% if (items.length > 0) { %>
                    <div class="main-block">
                        <div class="main-block-title"><%= cvData.customLabels && cvData.customLabels[sectionId] ? cvData.customLabels[sectionId] : (LABELS[sectionId] || sectionId.toUpperCase()) %></div>
                        <% items.forEach(function(item, idx) { %>
                            <div class="tl-row">
                                <div class="tl-date-col">
                                    <div class="tl-date-company"><%- item.school || item.company || '' %></div>
                                    <div class="tl-date-val"><%- item.period || '' %></div>
                                </div>
                                <div class="tl-dot-col">
                                    <div class="tl-dot"></div>
                                    <% if (idx < items.length - 1) { %><div class="tl-vline"></div><% } %>
                                </div>
                                <div class="tl-main-col">
                                    <div class="tl-main-title"><%- item.name || item.degree || item.title || '' %></div>
                                    <div class="tl-main-sub"><%- item.degree || item.title || '' %></div>
                                    <div class="tl-main-desc prose"><%- item.description || '' %></div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            <% } %>
        <% }); %>
    </div>
</div>
</body>
</html>
