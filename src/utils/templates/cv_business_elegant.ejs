<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>CV Kinh tế - StitchRecruit</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,300;0,400;0,700;0,900;1,400&family=Merriweather:ital,wght@0,700;1,400&display=swap" rel="stylesheet">
<style>
  @page { size: A4; margin: 0; }
  * { box-sizing: border-box; -webkit-print-color-adjust: exact; margin: 0; padding: 0; }

  body {
    font-family: '<%= themeConfig.fontFamily || "Lato" %>', sans-serif;
    background: #fff;
    color: #2c2c3a;
    line-height: <%= themeConfig.lineSpacing || 1.5 %>;
    letter-spacing: <%= themeConfig.charSpacing || 0 %>px;
  }

  .cv-wrap { width: 210mm; min-height: 297mm; margin: 0 auto; display: flex; }

  /* ═══ RIGHT SIDEBAR (reversed layout — contacts on RIGHT) ═══════════════ */
  .main-col { flex: 1; padding: 36px 30px 36px 36px; }
  .right-sb { width: 66mm; flex-shrink: 0; background: #f5f6fa; border-left: 1px solid #e8eaf0; padding: 36px 20px; }

  /* ═══ MAIN — elegant serif professional ═══════════════════════════════════ */

  /* Top name block — left-aligned, no avatar */
  .name-block { margin-bottom: 22px; padding-bottom: 18px; border-bottom: 2px solid <%= themeConfig.primaryColor || '#3F51B5' %>; }
  .m-name {
    font-family: 'Merriweather', serif;
    font-size: 26px; font-weight: 700;
    color: #1a1a2e;
    line-height: 1.2; margin-bottom: 5px;
    letter-spacing: -0.3px;
  }
  .m-title {
    font-size: 12px; color: <%= themeConfig.primaryColor || '#3F51B5' %>;
    font-weight: 700; text-transform: uppercase;
    letter-spacing: 2px;
  }

  /* Summary box */
  .summary-box {
    background: <%= themeConfig.primaryColor || '#3F51B5' %>0d;
    border-left: 3px solid <%= themeConfig.primaryColor || '#3F51B5' %>;
    padding: 10px 14px;
    margin-bottom: 24px;
    border-radius: 0 4px 4px 0;
    font-size: 10.5px; color: #444; line-height: 1.65;
    font-style: italic;
  }
  .summary-box p { margin-bottom: 4px; }

  /* Section */
  .sec { margin-bottom: 22px; }
  .sec-title-wrap { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
  .sec-number {
    width: 22px; height: 22px;
    background: <%= themeConfig.primaryColor || '#3F51B5' %>;
    color: #fff; border-radius: 50%;
    font-size: 10px; font-weight: 900;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .sec-title {
    font-size: 13px; font-weight: 900;
    color: #1a1a2e; text-transform: uppercase;
    letter-spacing: 1px;
    flex: 1;
    border-bottom: 1px solid #e4e4e4;
    padding-bottom: 4px;
  }

  /* Item — two-column table feel */
  .item { display: flex; gap: 14px; margin-bottom: 16px; }
  .item-year {
    width: 52px; flex-shrink: 0;
    text-align: right;
    font-size: 9px; color: <%= themeConfig.primaryColor || '#3F51B5' %>;
    font-weight: 700; padding-top: 3px;
    line-height: 1.4;
  }
  .item-body { flex: 1; border-left: 1px dashed #d8dce6; padding-left: 14px; }
  .item-name { font-size: 12px; font-weight: 700; color: #1a1a2e; margin-bottom: 2px; }
  .item-sub {
    font-size: 10.5px; color: #555;
    font-style: italic; margin-bottom: 4px;
  }
  .item-desc { font-size: 9.5px; color: #666; line-height: 1.55; }
  .item-desc p { margin-bottom: 3px; }
  .item-desc ul { padding-left: 14px; }
  .item-desc li { margin-bottom: 2px; }

  /* ═══ RIGHT SIDEBAR ═══════════════════════════════════════════════════════ */
  .sb-avatar {
    width: 100px; height: 100px; border-radius: 50%;
    margin: 0 auto 18px;
    overflow: hidden; border: 3px solid <%= themeConfig.primaryColor || '#3F51B5' %>;
    background: #e8eaf0;
    display: flex; align-items: center; justify-content: center;
  }
  .sb-avatar img { width: 100%; height: 100%; object-fit: cover; }

  .sb-sec { margin-bottom: 20px; }
  .sb-title {
    font-size: 9px; font-weight: 900;
    text-transform: uppercase; letter-spacing: 1.5px;
    color: <%= themeConfig.primaryColor || '#3F51B5' %>;
    margin-bottom: 8px;
  }

  .ct-row { display: flex; align-items: flex-start; gap: 6px; margin-bottom: 8px; }
  .ct-icon {
    width: 16px; height: 16px; flex-shrink: 0;
    color: <%= themeConfig.primaryColor || '#3F51B5' %>;
    margin-top: 1px;
  }
  .ct-val { font-size: 9px; color: #444; line-height: 1.4; }

  .sb-text { font-size: 9px; color: #555; line-height: 1.6; }
  .sb-text p { margin-bottom: 3px; }
  .sb-text ul { padding-left: 12px; }
  .sb-text li { margin-bottom: 2px; }

  /* Divider */
  .sb-divider { height: 1px; background: #e0e3ee; margin: 14px 0; }

  .prose ul { padding-left: 1.2rem; margin: 0.3rem 0; }
  .prose li { margin-bottom: 2px; }
  .prose p { margin: 0 0 4px; }
</style>
</head>
<body>
<%
const layout = columnLayout || { left:['profile','contact','about','skills'], right:['experience','education','projects','awards'] };
const LABELS = { contact:'Liên hệ', about:'Mục tiêu', skills:'Kỹ năng', experience:'Kinh nghiệm', education:'Học vấn', projects:'Dự án', awards:'Giải thưởng' };
// Sequential section numbering
let secIdx = 0;
function nextNum() { secIdx++; return secIdx; }
%>
<div class="cv-wrap">

  <!-- MAIN COLUMN (left) -->
  <div class="main-col">
    <!-- Name block -->
    <div class="name-block">
      <div class="m-name"><%- (cvData.personal && cvData.personal.fullName) || 'Họ Tên' %></div>
      <div class="m-title"><%- (cvData.personal && cvData.personal.title) || 'Chuyên viên Kinh tế' %></div>
    </div>

    <% layout.right.forEach(function(sectionId) { %>
      <% if (sectionId === 'about') { %>
        <div class="summary-box prose"><%- cvData.about || '' %></div>
      <% } else if (sectionId === 'skills') { %>
        <div class="sec">
          <div class="sec-title-wrap">
            <div class="sec-number"><%= nextNum() %></div>
            <div class="sec-title">Kỹ năng</div>
          </div>
          <div class="item-desc prose"><%- cvData.skills || '' %></div>
        </div>
      <% } else { %>
        <% const items = cvData[sectionId] || []; %>
        <% if (items.length > 0) { %>
          <div class="sec">
            <div class="sec-title-wrap">
              <div class="sec-number"><%= nextNum() %></div>
              <div class="sec-title"><%= cvData.customLabels && cvData.customLabels[sectionId] ? cvData.customLabels[sectionId] : (LABELS[sectionId] || sectionId) %></div>
            </div>
            <% items.forEach(function(item) { %>
              <div class="item">
                <div class="item-year"><%- item.period || '' %></div>
                <div class="item-body">
                  <div class="item-name"><%- item.school || item.company || item.name || '' %></div>
                  <div class="item-sub"><%- item.degree || item.title || '' %></div>
                  <div class="item-desc prose"><%- item.description || '' %></div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      <% } %>
    <% }); %>
  </div>

  <!-- RIGHT SIDEBAR -->
  <div class="right-sb">
    <!-- Avatar -->
    <div class="sb-avatar">
      <% if (cvData.personal && cvData.personal.avatarUrl) { %>
        <img src="<%= cvData.personal.avatarUrl %>" alt="Avatar">
      <% } else { %>
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#9da5c0" stroke-width="1.5">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      <% } %>
    </div>

    <% layout.left.forEach(function(sectionId) { %>
      <% if (sectionId === 'profile') { %>
        <!-- done above -->
      <% } else if (sectionId === 'contact') { %>
        <div class="sb-sec">
          <div class="sb-title">Liên hệ</div>
          <% if (cvData.personal && cvData.personal.phoneNumber) { %>
            <div class="ct-row">
              <div class="ct-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
              <div class="ct-val"><%= cvData.personal.phoneNumber %></div>
            </div>
          <% } %>
          <% if (cvData.personal && cvData.personal.email) { %>
            <div class="ct-row">
              <div class="ct-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div>
              <div class="ct-val"><%= cvData.personal.email %></div>
            </div>
          <% } %>
          <% if (cvData.personal && cvData.personal.address) { %>
            <div class="ct-row">
              <div class="ct-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
              <div class="ct-val"><%= cvData.personal.address %></div>
            </div>
          <% } %>
        </div>
      <% } else if (sectionId === 'about') { %>
        <div class="sb-divider"></div>
        <div class="sb-sec">
          <div class="sb-title">Mục tiêu</div>
          <div class="sb-text prose"><%- cvData.about || '' %></div>
        </div>
      <% } else if (sectionId === 'skills') { %>
        <div class="sb-divider"></div>
        <div class="sb-sec">
          <div class="sb-title">Kỹ năng</div>
          <div class="sb-text prose"><%- cvData.skills || '' %></div>
        </div>
      <% } else { %>
        <% const sItems = cvData[sectionId] || []; %>
        <% if (sItems.length > 0) { %>
          <div class="sb-divider"></div>
          <div class="sb-sec">
            <div class="sb-title"><%= cvData.customLabels && cvData.customLabels[sectionId] ? cvData.customLabels[sectionId] : (LABELS[sectionId] || sectionId) %></div>
            <% sItems.forEach(function(it) { %>
              <div style="margin-bottom:8px;">
                <div style="font-size:9.5px;font-weight:700;color:#333;"><%- it.school || it.company || '' %></div>
                <div style="font-size:8.5px;color:<%= themeConfig.primaryColor || '#3F51B5' %>;"><%- it.degree || it.title || '' %></div>
                <div style="font-size:8px;color:#999;"><%- it.period || '' %></div>
              </div>
            <% }); %>
          </div>
        <% } %>
      <% } %>
    <% }); %>
  </div>
</div>
</body>
</html>
