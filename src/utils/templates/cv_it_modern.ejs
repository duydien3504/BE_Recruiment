<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>CV IT - StitchRecruit</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
<style>
  @page { size: A4; margin: 0; }
  * { box-sizing: border-box; -webkit-print-color-adjust: exact; margin: 0; padding: 0; }

  :root {
    --accent: <%= themeConfig.primaryColor || '#00b14f' %>;
    --dark:   #0d1117;
    --panel:  #161b22;
    --border: #30363d;
    --text:   #c9d1d9;
    --muted:  #8b949e;
  }

  body {
    font-family: '<%= themeConfig.fontFamily || "Inter" %>', sans-serif;
    background: #fff;
    color: #24292f;
    line-height: <%= themeConfig.lineSpacing || 1.5 %>;
    letter-spacing: <%= themeConfig.charSpacing || 0 %>px;
  }

  .cv-wrap { display: flex; width: 210mm; min-height: 297mm; margin: 0 auto; }

  /* ═══ SIDEBAR — dark terminal style ═══════════════════════════════════════ */
  .sb {
    width: 68mm; flex-shrink: 0;
    background: var(--panel);
    color: var(--text);
    display: flex; flex-direction: column;
  }

  /* Header with gradient accent bar */
  .sb-top {
    padding: 28px 20px 22px;
    background: linear-gradient(180deg, var(--dark) 0%, var(--panel) 100%);
    border-bottom: 2px solid var(--accent);
    position: relative;
  }
  .sb-top::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--accent);
  }

  .avatar-wrap {
    width: 100px; height: 100px; border-radius: 8px;
    border: 2px solid var(--border);
    margin: 0 auto 14px;
    overflow: hidden;
    background: var(--dark);
    display: flex; align-items: center; justify-content: center;
  }
  .avatar-wrap img { width: 100%; height: 100%; object-fit: cover; }

  /* Monospace name — code aesthetic */
  .sb-name {
    font-family: 'Fira Code', monospace;
    font-size: 14px; font-weight: 500;
    color: var(--accent);
    text-align: center;
    margin-bottom: 4px;
    letter-spacing: 0.5px;
  }
  .sb-name::before { content: '> '; opacity: 0.5; }
  .sb-title {
    font-size: 9px; color: var(--muted);
    text-align: center; font-style: italic;
  }

  /* Sidebar body */
  .sb-body { padding: 16px 18px; flex: 1; }
  .sb-sec { margin-bottom: 20px; }
  .sb-sec-title {
    font-family: 'Fira Code', monospace;
    font-size: 8px; font-weight: 500;
    color: var(--accent);
    letter-spacing: 2px; text-transform: uppercase;
    border-bottom: 1px solid var(--border);
    padding-bottom: 5px; margin-bottom: 10px;
    display: flex; align-items: center; gap: 6px;
  }
  .sb-sec-title::before { content: '//'; opacity: 0.4; }

  /* Contact */
  .ct-row { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 8px; }
  .ct-icon {
    width: 18px; height: 18px; border-radius: 4px;
    background: var(--border);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; color: var(--accent);
  }
  .ct-val { font-size: 9px; color: var(--text); line-height: 1.5; word-break: break-all; padding-top: 1px; }

  /* Skills tags */
  .skill-tags { display: flex; flex-wrap: wrap; gap: 5px; }
  .tag {
    display: inline-block;
    padding: 2px 8px; border-radius: 3px;
    background: var(--border);
    color: var(--accent);
    font-family: 'Fira Code', monospace;
    font-size: 8px; font-weight: 500;
    border: 1px solid var(--accent)33;
  }

  .sb-text { font-size: 9px; color: var(--muted); line-height: 1.6; }
  .sb-text p { margin-bottom: 4px; }
  .sb-text ul { padding-left: 14px; }
  .sb-text li { margin-bottom: 2px; }

  /* ═══ MAIN — clean white ══════════════════════════════════════════════════ */
  .main { flex: 1; padding: 30px 28px; background: #fff; }

  /* Section */
  .sec { margin-bottom: 24px; }
  .sec-hd {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 14px;
    padding-bottom: 6px;
    border-bottom: 1px solid #e1e4e8;
    position: relative;
  }
  .sec-hd::after {
    content: '';
    position: absolute; bottom: -1px; left: 0;
    width: 40px; height: 2px;
    background: var(--accent);
  }
  .sec-hd-icon {
    width: 26px; height: 26px; border-radius: 6px;
    background: var(--accent)18;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .sec-title {
    font-size: 12px; font-weight: 700;
    color: #24292f; text-transform: uppercase;
    letter-spacing: 0.8px;
  }

  /* Items */
  .item { margin-bottom: 16px; padding-left: 12px; border-left: 2px solid #e1e4e8; position: relative; }
  .item::before {
    content: '';
    position: absolute; left: -5px; top: 6px;
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent);
    border: 2px solid #fff;
    outline: 1px solid var(--accent);
  }
  .item-hd { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2px; }
  .item-name { font-size: 12px; font-weight: 700; color: #24292f; }
  .item-period {
    font-family: 'Fira Code', monospace;
    font-size: 8.5px; color: var(--muted);
    white-space: nowrap; margin-top: 2px;
  }
  .item-sub { font-size: 10px; color: var(--accent); font-weight: 500; margin-bottom: 5px; }
  .item-desc { font-size: 9.5px; color: #57606a; line-height: 1.5; }
  .item-desc p { margin-bottom: 3px; }
  .item-desc ul { padding-left: 14px; }
  .item-desc li { margin-bottom: 2px; }

  .prose ul { padding-left: 1.2rem; margin: 0.3rem 0; }
  .prose li { margin-bottom: 2px; }
  .prose p { margin: 0 0 4px; }
</style>
</head>
<body>
<%
const layout = columnLayout || { left:['profile','contact','about','skills'], right:['experience','education','projects','awards'] };
const LABELS = { contact:'Liên hệ', about:'Mục tiêu', skills:'Kỹ năng', experience:'Kinh nghiệm', education:'Học vấn', projects:'Dự án', awards:'Giải thưởng' };
const ICONS = {
  experience: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>',
  education:  '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>',
  projects:   '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>',
  awards:     '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>'
};
%>
<div class="cv-wrap">

  <!-- SIDEBAR -->
  <div class="sb">
    <div class="sb-top">
      <div class="avatar-wrap">
        <% if (cvData.personal && cvData.personal.avatarUrl) { %>
          <img src="<%= cvData.personal.avatarUrl %>" alt="Avatar">
        <% } else { %>
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#30363d" stroke-width="1.5">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
        <% } %>
      </div>
      <div class="sb-name"><%- (cvData.personal && cvData.personal.fullName) || 'Họ Tên' %></div>
      <div class="sb-title"><%- (cvData.personal && cvData.personal.title) || 'Software Engineer' %></div>
    </div>

    <div class="sb-body">
      <% layout.left.forEach(function(sectionId) { %>
        <% if (sectionId === 'profile') { %>
          <!-- profile already in sb-top -->
        <% } else if (sectionId === 'contact') { %>
          <div class="sb-sec">
            <div class="sb-sec-title">Liên hệ</div>
            <% if (cvData.personal && cvData.personal.phoneNumber) { %>
              <div class="ct-row">
                <div class="ct-icon"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
                <div class="ct-val"><%= cvData.personal.phoneNumber %></div>
              </div>
            <% } %>
            <% if (cvData.personal && cvData.personal.email) { %>
              <div class="ct-row">
                <div class="ct-icon"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div>
                <div class="ct-val"><%= cvData.personal.email %></div>
              </div>
            <% } %>
            <% if (cvData.personal && cvData.personal.address) { %>
              <div class="ct-row">
                <div class="ct-icon"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
                <div class="ct-val"><%= cvData.personal.address %></div>
              </div>
            <% } %>
          </div>
        <% } else if (sectionId === 'about') { %>
          <div class="sb-sec">
            <div class="sb-sec-title">Giới thiệu</div>
            <div class="sb-text"><%- cvData.about || '' %></div>
          </div>
        <% } else if (sectionId === 'skills') { %>
          <div class="sb-sec">
            <div class="sb-sec-title">Kỹ năng</div>
            <div class="sb-text"><%- cvData.skills || '' %></div>
          </div>
        <% } else { %>
          <% const sItems = cvData[sectionId] || []; %>
          <% if (sItems.length > 0) { %>
            <div class="sb-sec">
              <div class="sb-sec-title"><%= cvData.customLabels && cvData.customLabels[sectionId] ? cvData.customLabels[sectionId] : (LABELS[sectionId] || sectionId) %></div>
              <% sItems.forEach(function(it) { %>
                <div style="margin-bottom:8px;">
                  <div style="font-size:9px;font-weight:700;color:#c9d1d9;"><%- it.school || it.company || it.name || '' %></div>
                  <div style="font-size:8.5px;color:<%= themeConfig.primaryColor || '#00b14f' %>;"><%- it.degree || it.title || '' %></div>
                  <div style="font-size:8px;color:#8b949e;"><%- it.period || '' %></div>
                </div>
              <% }); %>
            </div>
          <% } %>
        <% } %>
      <% }); %>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div class="main">
    <% layout.right.forEach(function(sectionId) { %>
      <% if (sectionId === 'about') { %>
        <div class="sec">
          <div class="sec-hd">
            <div class="sec-hd-icon" style="color:<%= themeConfig.primaryColor || '#00b14f' %>;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
            </div>
            <div class="sec-title">Giới thiệu</div>
          </div>
          <div class="item-desc prose"><%- cvData.about || '' %></div>
        </div>
      <% } else if (sectionId === 'skills') { %>
        <div class="sec">
          <div class="sec-hd">
            <div class="sec-hd-icon" style="color:<%= themeConfig.primaryColor || '#00b14f' %>;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3z"/></svg>
            </div>
            <div class="sec-title">Kỹ năng</div>
          </div>
          <div class="item-desc prose"><%- cvData.skills || '' %></div>
        </div>
      <% } else { %>
        <% const items = cvData[sectionId] || []; %>
        <% if (items.length > 0) { %>
          <div class="sec">
            <div class="sec-hd">
              <div class="sec-hd-icon" style="color:<%= themeConfig.primaryColor || '#00b14f' %>;"><%- ICONS[sectionId] || '' %></div>
              <div class="sec-title"><%= cvData.customLabels && cvData.customLabels[sectionId] ? cvData.customLabels[sectionId] : (LABELS[sectionId] || sectionId) %></div>
            </div>
            <% items.forEach(function(item) { %>
              <div class="item">
                <div class="item-hd">
                  <div class="item-name"><%- item.school || item.company || item.name || '' %></div>
                  <div class="item-period"><%- item.period || '' %></div>
                </div>
                <div class="item-sub"><%- item.degree || item.title || '' %></div>
                <div class="item-desc prose"><%- item.description || '' %></div>
              </div>
            <% }); %>
          </div>
        <% } %>
      <% } %>
    <% }); %>
  </div>
</div>
</body>
</html>
