# ==========================================
# DOCKER HUB
# ==========================================
# Docker Hub Username (Dùng để build image docker-compose)
DOCKER_HUB_USERNAME=your_docker_username_here

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=8080
NODE_ENV=development

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=your_db_host_here
DB_PORT=5432
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here
DB_NAME=your_db_name_here

# ==========================================
# JWT (JSON WEB TOKEN) CONFIGURATION
# ==========================================
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
ACCESS_TOKEN_EXPIRATION=1d
REFRESH_TOKEN_EXPIRATION=7d

# ==========================================
# SMTP EMAIL CONFIGURATION
# ==========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email_address_here
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=your_email_address_here

# ==========================================
# CLOUDINARY CONFIGURATION (IMAGE UPLOAD)
# ==========================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==========================================
# MOMO PAYMENT GATEWAY CONFIGURATION
# ==========================================
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:8080/api/v1/payments/callback
MOMO_IPN_URL=http://localhost:8080/api/v1/payments/ipn
MOMO_EMPLOYER_RETURN_URL=http://localhost:8080/api/v1/auth/employer/payment-callback

# ==========================================
# OPENROUTER AI CONFIGURATION
# ==========================================
API_KEY=your_openrouter_api_key
API_URL=https://openrouter.ai/api/v1/chat/completions
MODEL=openai/gpt-3.5-turbo
